---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import LeadForm from '../../components/LeadForm.astro';
import FAQ from '../../components/FAQ.astro';
import { SITE, PRODUCTS } from '../../consts';

const faqs = [
  {
    q: '¿Se puede tener un puntaje de crédito con un ITIN?',
    a: 'Sí. Los tres burós de crédito principales — Experian, Equifax y TransUnion — pueden crear un expediente de crédito bajo un ITIN. Una vez que abres al menos una cuenta que reporta y haces pagos a tiempo durante seis meses, se genera un puntaje FICO. No existe ninguna barrera legal que impida a las personas con ITIN tener un puntaje de crédito en EE. UU.',
  },
  {
    q: '¿Qué rango de puntaje necesito para los productos financieros comunes?',
    a: 'Los puntajes de crédito en EE. UU. van de 300 a 850. Las tarjetas aseguradas y los préstamos para crédito normalmente no piden un puntaje mínimo — están diseñados para personas con expediente delgado. Los productos sin garantía suelen pedir 580–640+. Un puntaje de 670 es la entrada al crédito "bueno" y a mejores tasas de interés.',
  },
  {
    q: '¿Cuánto tarda construir un puntaje de crédito con un ITIN?',
    a: 'FICO requiere al menos seis meses de historial de cuenta reportado para calcular un puntaje. La mayoría de las personas con ITIN que abren una tarjeta asegurada o un préstamo para crédito tienen un expediente con puntaje entre 6 y 12 meses. Pasar de no tener puntaje a un buen puntaje (670+) suele tomar de uno a dos años de pagos constantes a tiempo.',
  },
  {
    q: '¿Qué factor importa más para mi puntaje de crédito?',
    a: 'El historial de pagos es el factor más grande, con 35% de tu puntaje FICO. Pagar a tiempo, siempre, es lo más importante que puedes hacer. Los montos adeudados (utilización) son el segundo factor, con 30%. Juntos representan el 65% de tu puntaje.',
  },
  {
    q: '¿ITINCreditScore.com es un buró de crédito o un servicio de reparación de crédito?',
    a: 'No. Somos un recurso independiente de información y conexión con herramientas. No somos un buró de crédito, una organización de reparación de crédito, un prestamista ni un asesor financiero. No entregamos puntajes de crédito, no reparamos crédito ni originamos préstamos. Nuestras guías son educativas y nuestra conexión con herramientas es un servicio de referencia.',
  },
];
---
<BaseLayout title={SITE.name}>
  <!-- Hero -->
  <section class="hero hero--image">
    <img class="hero-bg" src="/img/credit-building.webp" alt="Una persona revisando su puntaje de crédito en crecimiento en el teléfono" loading="eager" fetchpriority="high" decoding="async" />
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">Sin Seguro Social</span>
        <h1>Construye y revisa tu puntaje de crédito con un ITIN</h1>
        <p class="lede">
          No necesitas un Seguro Social para tener un puntaje de crédito en
          EE. UU. Ayudamos a las personas con ITIN a entender cómo funciona el
          puntaje de crédito, revisar sus reportes y construir un historial
          crediticio sólido desde cero — paso a paso, en español claro.
        </p>
        <div class="hero-cta">
          <a href="/es/apply" class="btn btn-primary btn-lg">Empieza a construir crédito</a>
          <a href="/es/itin-credit-score-guide" class="btn btn-secondary btn-lg">Cómo funciona</a>
        </div>
        <div class="hero-trust">
          <span><span class="check">&#10003;</span> Sin Seguro Social</span>
          <span><span class="check">&#10003;</span> Revisar tu puntaje no lo afecta</span>
          <span><span class="check">&#10003;</span> Los 50 estados</span>
        </div>
      </div>
      <div>
        <LeadForm heading="Conéctate con herramientas en 60 segundos" compact={true} />
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>¿Qué puedes hacer con un ITIN?</h2>
        <p>Las personas con ITIN pueden construir, revisar y mejorar un puntaje de crédito en EE. UU. Elige por dónde quieres empezar.</p>
      </div>
      <div class="card-grid">
        {PRODUCTS.map((p) => (
          <a class="card" href={`/es/${p.slug}`}>
            <div class="card-icon"><Icon name={p.icon} size={28} /></div>
            <h3>{p.labelEs}</h3>
            <p>{p.blurbEs}</p>
            <span class="arrow">Más información &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section-surface">
    <div class="container">
      <div class="section-head">
        <h2>Cómo funciona construir crédito con un ITIN</h2>
        <p>Tres pasos para pasar de "¿Acaso tengo un expediente de crédito?" a un puntaje activo y en crecimiento.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="num">1</div>
          <h3>Revisa tu punto de partida</h3>
          <p>Saca tu reporte de crédito de los tres burós en AnnualCreditReport.com usando tu ITIN. Si todavía no existe un expediente, solo significa que no has abierto una cuenta que reporta — no es una barrera.</p>
        </div>
        <div class="step">
          <div class="num">2</div>
          <h3>Abre una cuenta que reporta</h3>
          <p>Una tarjeta de crédito asegurada o un préstamo para crédito que acepte ITIN y reporte a los tres burós es tu herramienta inicial. Paga a tiempo cada mes y mantén bajos los saldos de la tarjeta.</p>
        </div>
        <div class="step">
          <div class="num">3</div>
          <h3>Mira crecer tu puntaje</h3>
          <p>Después de seis meses de historial de pagos positivo, se genera un puntaje FICO. Sigue pagando a tiempo, mantén baja la utilización y tu puntaje crece hacia el rango 670+ que abre los productos comunes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / trust -->
  <section class="section-tight">
    <div class="container">
      <div class="stats">
        <div class="stat"><div class="big">300–850</div><div class="lbl">Rango del puntaje de crédito en EE. UU.</div></div>
        <div class="stat"><div class="big">35%</div><div class="lbl">Peso del historial de pagos en FICO</div></div>
        <div class="stat"><div class="big">3</div><div class="lbl">Burós de crédito principales</div></div>
        <div class="stat"><div class="big">$0</div><div class="lbl">Costo de revisar tus reportes</div></div>
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="section">
    <div class="container">
      <div class="cta-band">
        <h2>Tu ITIN es suficiente para empezar.</h2>
        <p>Millones de personas con ITIN están construyendo crédito en EE. UU. ahora mismo. Lo único entre tú y un expediente de crédito es abrir una cuenta que reporta y pagarla a tiempo. Te ayudamos a encontrar la indicada.</p>
        <a href="/es/apply" class="btn btn-primary btn-lg">Empieza a construir crédito</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-surface">
    <div class="container narrow">
      <FAQ faqs={faqs} heading="Puntajes de crédito con ITIN: preguntas comunes" />
    </div>
  </section>
</BaseLayout>
