---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import Icon from '../components/Icon.astro';

const title = 'Start Building Credit With an ITIN';
const description =
  'Get matched with ITIN-friendly credit-building tools, secured cards, credit-builder loans, and more. No SSN required. Free and no impact to your credit to check.';
---
<BaseLayout title={title} description={description} path="/apply" noindex={true}>
  <section class="section">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">Free &amp; no credit impact</span>
        <h1>Start building credit with an ITIN</h1>
        <p class="lede">
          Tell us your credit-building goal and we'll match you with
          ITIN-friendly tools, secured cards, credit-builder loans, and more.
          No SSN required, no obligation, and checking your options never
          affects your credit score.
        </p>
        <ul class="lead-list" style="color:var(--muted)">
          <li><strong style="color:var(--text)">Built for ITIN holders</strong>, tools here accept an ITIN in place of an SSN.</li>
          <li><strong style="color:var(--text)">All credit-building stages</strong>, starting from zero, improving a score, or adding a new account.</li>
          <li><strong style="color:var(--text)">No pressure</strong>, explore options and decide on your own timeline.</li>
        </ul>
        <p style="display:inline-flex;align-items:center;gap:8px;color:var(--accent-dark);font-weight:600">
          <Icon name="shield" size={20} /> Your information is kept private.
        </p>
      </div>
      <div>
        <LeadForm heading="Get matched with credit-building tools" />
      </div>
    </div>
  </section>
</BaseLayout>
