---
import { SITE } from '../consts';
import { getLangFromUrl, localizedHref } from '../i18n/ui';

// Reusable conversion CTA dropped mid-article and at the end of money pages.
// Routes to the off-site affiliate apply URL when configured, else to /apply.
interface Props {
  heading?: string;
  sub?: string;
  label?: string;
}
const lang = getLangFromUrl(Astro.url);
const copy =
  lang === 'es'
    ? {
        heading: '¿Listo para explorar tus opciones?',
        sub: 'Empieza a construir crédito en EE. UU. con tu ITIN. Sin Seguro Social y revisar no afecta tu crédito.',
        label: 'Empieza a construir crédito',
      }
    : {
        heading: 'Ready to explore your options?',
        sub: 'Start building U.S. credit with an ITIN. No SSN required, no impact to your credit score to check.',
        label: 'Start building credit',
      };
const {
  heading = copy.heading,
  sub = copy.sub,
  label = copy.label,
} = Astro.props;

const href = SITE.monetize.affiliateApplyUrl || localizedHref('/apply', lang);
const external = href.startsWith('http');
---
<div class="inline-cta">
  <h3>{heading}</h3>
  <p style="color:var(--muted);max-width:34em;margin:0 auto 18px">{sub}</p>
  <a
    class="btn btn-primary btn-lg"
    href={href}
    {...external ? { rel: 'sponsored nofollow', target: '_blank' } : {}}
  >{label}</a>
</div>
