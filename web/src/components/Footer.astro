---
import { SITE, PRODUCTS } from '../consts';
import { getLangFromUrl, useTranslations, localizedHref } from '../i18n/ui';
const year = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEs = lang === 'es';
const L = (href: string) => localizedHref(href, lang);

const resources = isEs
  ? [
      { label: 'Guía de Puntaje', href: '/itin-credit-score-guide' },
      { label: 'Todas las Guías', href: '/articles' },
      { label: 'Empieza a construir crédito', href: '/apply' },
      { label: 'Nosotros', href: '/about' },
      { label: 'Contacto', href: '/contact' },
    ]
  : [
      { label: 'Credit Score Guide', href: '/itin-credit-score-guide' },
      { label: 'All Guides', href: '/articles' },
      { label: 'Start Building Credit', href: '/apply' },
      { label: 'About Us', href: '/about' },
      { label: 'Contact', href: '/contact' },
    ];

const legal = isEs
  ? [
      { label: 'Política Editorial', href: '/editorial-policy' },
      { label: 'Política de Privacidad', href: '/privacy' },
      { label: 'Términos de Uso', href: '/terms' },
      { label: 'Aviso para Anunciantes', href: '/disclosure' },
    ]
  : [
      { label: 'Editorial Policy', href: '/editorial-policy' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Use', href: '/terms' },
      { label: 'Advertiser Disclosure', href: '/disclosure' },
    ];

const tagline = isEs ? SITE.taglineEs : SITE.tagline;
const loanTypesHeading = isEs ? 'Temas de Crédito' : 'Credit Topics';
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">{SITE.name}<span style="color:var(--accent)">.</span></div>
        <p>{tagline}.</p>
        <h4>{t('footer.trust')}</h4>
        <ul class="footer-trust">
          <li><span class="tick">&#10003;</span> {t('footer.trust.independent')}</li>
          <li><span class="tick">&#10003;</span> {t('footer.trust.free')}</li>
          <li><span class="tick">&#10003;</span> {t('footer.trust.privacy')}</li>
        </ul>
        <p style="margin-top:14px"><a href={`mailto:${SITE.supportEmail}`}>Contact</a></p>
      </div>
      <div>
        <h4>{loanTypesHeading}</h4>
        <ul class="footer-links">
          {PRODUCTS.map((p) => (
            <li><a href={L(`/${p.slug}`)}>{isEs ? p.labelEs : p.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4>{t('footer.resources')}</h4>
        <ul class="footer-links">
          {resources.map((r) => <li><a href={L(r.href)}>{r.label}</a></li>)}
        </ul>
      </div>
      <div>
        <h4>{t('footer.legal')}</h4>
        <ul class="footer-links">
          {legal.map((r) => <li><a href={L(r.href)}>{r.label}</a></li>)}
        </ul>
      </div>
    </div>
    <div class="footer-disclaimer">
      {isEs ? (
        <p>
          &copy; {year} {SITE.legalName}, operado por {SITE.publisher.name}. Todos los derechos reservados.
          {SITE.name} es un recurso independiente de información y referencia. No
          somos un banco, prestamista, buró de crédito ni asesor financiero, y
          no tomamos decisiones de crédito, no fijamos tu puntaje ni originamos
          préstamos. La información de este sitio tiene fines educativos generales
          y no constituye asesoría financiera, legal ni fiscal. Los productos de
          crédito y los modelos de puntaje los controlan prestamistas y burós
          externos y están sujetos a su aprobación y a la ley
          aplicable. Podemos recibir compensación cuando haces clic en ciertos
          enlaces o te conectamos con un prestamista o producto de crédito, consulta nuestro
          <a href={L('/disclosure')}>Aviso para Anunciantes</a>.
        </p>
      ) : (
        <p>
          &copy; {year} {SITE.legalName}, operated by {SITE.publisher.name}. All rights reserved.
          {SITE.name} is an independent information and referral resource. We are
          not a bank, lender, credit bureau, or financial advisor, and we do not
          make credit decisions, set your score, or originate loans. Information on
          this site is for general educational purposes only and is not financial,
          legal, or tax advice. Credit products and scoring models are controlled
          by third-party lenders and bureaus and are subject to their approval,
          eligibility requirements, and applicable law. We may receive compensation
          when you click certain links or are matched with a lender or credit
          product, see our
          <a href={L('/disclosure')}>Advertiser Disclosure</a>.
        </p>
      )}
    </div>
  </div>
</footer>
